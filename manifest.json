{
  "manifest_version": 3,
  "name": "ReviewLens",
  "version": "2.0",
  "description": "AI-powered Amazon review trust analyzer. See what star ratings hide.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.amazon.com/*",
    "https://www.amazon.in/*",
    "https://www.amazon.co.uk/*",
    "https://www.amazon.ca/*",
    "https://www.amazon.com.au/*",
    "https://www.amazon.de/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com/*/dp/*",
        "https://www.amazon.com/dp/*",
        "https://www.amazon.in/*/dp/*",
        "https://www.amazon.in/dp/*",
        "https://www.amazon.co.uk/*/dp/*",
        "https://www.amazon.co.uk/dp/*",
        "https://www.amazon.ca/*/dp/*",
        "https://www.amazon.ca/dp/*",
        "https://www.amazon.com.au/*/dp/*",
        "https://www.amazon.com.au/dp/*",
        "https://www.amazon.de/*/dp/*",
        "https://www.amazon.de/dp/*"
      ],
      "js": ["cache.js", "local-analysis.js", "scraper.js", "ui.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
